$PRODUCES llm.c

$BUILTIN llm
$DEPENDS_ON HAVE_LLM
$FUNCTION llm_builtin
$SHORT_DOC llm [-c] [query ...] | remember | forget | memories | cleanup | cron
Send a query to an LLM and run the agentic tool loop.

Options:
  -c	clear conversation history

Memory subcommands:
  remember <text>   save a fact to long-term memory
  forget <id>       delete a memory by ID
  forget <text>     delete memories matching text
  memories          list all saved memories
  cleanup           run memory cleanup (split, deduplicate, resolve)

Cron subcommands:
  cron              list scheduled tasks
  cron list         list scheduled tasks
  cron remove <id>  remove a scheduled task

Concatenates arguments into a query and sends it to the configured
LLM server. The LLM can call tools (ls, cat, grep, run, man,
etc.) and will iterate until it produces a final text answer or
the max iterations limit is reached.

Relevant long-term memories are automatically injected into the
system prompt before each query by the global memory side agent.

LLM responses stream to stdout. Tool status goes to stderr.

Configuration is read from ~/.bashllmrc (INI format). See llm_init
and llm_config for details.

Exit Status:
Returns success unless the LLM request fails.
$END

#include <config.h>

#if defined (HAVE_LLM)

#if defined (HAVE_UNISTD_H)
#  include <unistd.h>
#endif

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#include "../shell.h"
#include "common.h"
#include "bashgetopt.h"

#include "../lib/llm/llm_shell.h"
#include "../lib/llm/llm_api.h"
#include "../lib/llm/llm_history.h"
#include "../lib/llm/llm_global_mem_agent.h"
#include "../lib/llm/llm_cron_agent.h"
#include "../lib/llm/llm_side_agent.h"
#include "../lib/llm/llm_log.h"
#include "../lib/llm/llm_streams.h"
#include "../lib/llm/llm_serverconf.h"
#include "../lib/llm/llm_router.h"
#include "../lib/llm/llm_manscan.h"
#include "../lib/llm/llm_tools.h"

/* Global state for the LLM subsystem (non-static: shared with llm_init, llm_config) */
int g_llm_initialized = 0;
server_config_t *g_servers = NULL;
llm_shell_ctx_t g_ctx;
llm_stream_cbs g_stream_cbs;

/* Streaming callbacks (non-static: shared with llm_init) */
/* Build ~/.aibash_llm_history path. Returns static buffer. */
const char *llm_history_path(void)
{
    static char path[4096];
    const char *home = getenv("HOME");
    if (home)
        snprintf(path, sizeof(path), "%s/.aibash_llm_history", home);
    else
        snprintf(path, sizeof(path), ".aibash_llm_history");
    return path;
}

void chat_token_cb(const char *token, void *userdata)
{
    (void)userdata;
    stream_chat_output(token);
}

void think_token_cb(const char *token, void *userdata)
{
    (void)userdata;
    stream_think_output(token);
}

/* Auto-initialize if not already done */
static int ensure_initialized(void)
{
    if (g_llm_initialized)
        return 0;

    /* Load config */
    g_servers = llm_serverconf_load();
    if (!g_servers) {
        builtin_error("failed to load LLM configuration");
        return 1;
    }

    const server_entry_t *active = llm_serverconf_active(g_servers);

    /* Initialize subsystems */
    if (llm_api_init(active->api_url, active->model, active->api_key) != 0) {
        builtin_error("failed to initialize LLM API client");
        llm_serverconf_free(g_servers);
        g_servers = NULL;
        return 1;
    }

    llm_streams_init();
    llm_history_init(llm_history_path());
    llm_manscan_init();
    llm_tools_init();
    llm_router_init(g_servers);

    /* Initialize global memory agent (owns the memory store) */
    if (g_servers->memory_enabled) {
        char memdir[4096];
        const char *home = getenv("HOME");
        snprintf(memdir, sizeof(memdir), "%s/.aibash_memories", home ? home : ".");

        llm_global_mem_agent_init(memdir, g_servers->memory_max,
                                  g_servers->memory_api_url,
                                  g_servers->memory_model,
                                  g_servers->memory_api_key);

        /* Initialize API logging */
        char logdir[4096];
        snprintf(logdir, sizeof(logdir), "%s/logs", memdir);
        llm_log_init(logdir);
    }

    /* Initialize cron agent */
    {
        char crondir[4096];
        const char *home = getenv("HOME");
        snprintf(crondir, sizeof(crondir), "%s/.aibash_cron", home ? home : ".");
        llm_cron_agent_init(crondir);
    }

    /* Initialize side agent framework (registers all agents) */
    side_agent_init();

    /* Set up streaming callbacks */
    g_stream_cbs.on_token = chat_token_cb;
    g_stream_cbs.on_thinking = think_token_cb;
    g_stream_cbs.userdata = NULL;

    /* Set up context */
    g_ctx.servers = g_servers;
    g_ctx.cbs = &g_stream_cbs;
    g_ctx.last_output = NULL;
    g_ctx.max_iterations = g_servers->max_iterations;

    g_llm_initialized = 1;
    return 0;
}

int
llm_builtin (WORD_LIST *list)
{
    int opt, clear_flag = 0;

    /* Auto-init */
    if (ensure_initialized() != 0)
        return (EXECUTION_FAILURE);

    reset_internal_getopt();
    while ((opt = internal_getopt(list, "c")) != -1) {
        switch (opt) {
        case 'c':
            clear_flag = 1;
            break;
            CASE_HELPOPT;
        default:
            builtin_usage();
            return (EX_USAGE);
        }
    }
    list = loptend;

    if (clear_flag) {
        llm_history_cleanup();
        llm_history_init(llm_history_path());
        free(g_ctx.last_output);
        g_ctx.last_output = NULL;
        stream_chat_output("Conversation history cleared.\n");
        if (!list)
            return (EXECUTION_SUCCESS);
    }

    /* No arguments = nothing to do */
    if (!list) {
        builtin_usage();
        return (EX_USAGE);
    }

    /* Check for memory subcommands */
    if (list && list->word->word) {
        const char *cmd = list->word->word;

        if (strcmp(cmd, "remember") == 0) {
            list = list->next;
            if (!list) {
                builtin_error("remember requires text");
                return (EXECUTION_FAILURE);
            }
            char *text = string_list(list);
            if (llm_global_mem_remember(text) == 0)
                printf("Remembered: %s\n", text);
            else
                builtin_error("failed to save memory");
            free(text);
            return (EXECUTION_SUCCESS);
        }

        if (strcmp(cmd, "forget") == 0) {
            list = list->next;
            if (!list) {
                builtin_error("forget requires an ID or text");
                return (EXECUTION_FAILURE);
            }
            const char *arg = list->word->word;
            /* Try as numeric ID first */
            char *endp;
            long id = strtol(arg, &endp, 10);
            if (*endp == '\0' && endp != arg) {
                if (llm_global_mem_forget((int)id) == 0)
                    printf("Forgot memory #%ld\n", id);
                else
                    builtin_error("memory #%ld not found", id);
            } else {
                char *text = string_list(list);
                if (llm_global_mem_forget_match(text) == 0)
                    printf("Forgot matching memories\n");
                else
                    builtin_error("no matching memories found");
                free(text);
            }
            return (EXECUTION_SUCCESS);
        }

        if (strcmp(cmd, "memories") == 0) {
            char *list_text = llm_global_mem_list();
            printf("%s", list_text);
            free(list_text);
            return (EXECUTION_SUCCESS);
        }

        if (strcmp(cmd, "cleanup") == 0) {
            if (!llm_global_mem_agent_ready()) {
                builtin_error("memory agent not configured (need [memory] section in ~/.bashllmrc)");
                return (EXECUTION_FAILURE);
            }
            printf("Running memory cleanup...\n");
            fflush(stdout);

            llm_global_mem_agent_cleanup_run(g_servers->memory_max);
            printf("Cleanup complete.\n");

            return (EXECUTION_SUCCESS);
        }

        if (strcmp(cmd, "cron") == 0) {
            list = list->next;
            if (!list || strcmp(list->word->word, "list") == 0) {
                char *jobs = llm_cron_list();
                printf("%s", jobs);
                free(jobs);
                return (EXECUTION_SUCCESS);
            }
            const char *sub = list->word->word;
            if (strcmp(sub, "remove") == 0) {
                list = list->next;
                if (!list) {
                    builtin_error("cron remove requires an ID");
                    return (EXECUTION_FAILURE);
                }
                int id = atoi(list->word->word);
                if (llm_cron_remove(id) == 0)
                    printf("Removed scheduled task #%d\n", id);
                else
                    builtin_error("task #%d not found", id);
                return (EXECUTION_SUCCESS);
            }
            builtin_error("unknown cron subcommand: %s (use: list, remove)", sub);
            return (EXECUTION_FAILURE);
        }

        if (strcmp(cmd, "sideagent") == 0) {
            list = list->next;
            if (!list) {
                builtin_error("sideagent requires a query");
                return (EXECUTION_FAILURE);
            }
            char *query = string_list(list);
            char cwd[4096];
            if (!getcwd(cwd, sizeof(cwd))) strcpy(cwd, ".");
            printf("Running side agents for: %s\n", query);
            fflush(stdout);
            char *result = side_agents_pre_query(query, cwd);
            if (result) {
                printf("%s", result);
                free(result);
            } else {
                printf("(no context returned)\n");
            }
            free(query);
            return (EXECUTION_SUCCESS);
        }
    }

    /* Concatenate arguments into query string */
    char *query = string_list(list);
    if (!query || !*query) {
        free(query);
        return (EXECUTION_SUCCESS);
    }

    /* Run the agentic loop */
    char *result = llm_shell_query(&g_ctx, query, NULL);
    free(query);

    if (result) {
        /* Final text was already streamed via callback */
        free(result);
    }

    /* Sync working directory in case LLM's cd tool changed it */
    {
        char cwd[4096];
        if (getcwd(cwd, sizeof(cwd)))
            set_working_directory(cwd);
    }

    return (EXECUTION_SUCCESS);
}

#else /* !HAVE_LLM */

int
llm_builtin (WORD_LIST *list)
{
    (void)list;
    builtin_error("LLM support not compiled in (configure with --enable-llm)");
    return (EXECUTION_FAILURE);
}

#endif /* HAVE_LLM */
